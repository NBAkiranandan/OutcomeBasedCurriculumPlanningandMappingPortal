{
  "name": "obcpmp",
  "private": true,
  "scripts": {
    "dev": "npm run dev --prefix frontend",
    "dev:backend": "npm run dev --prefix backend",
    "dev:all": "concurrently \"npm run dev --prefix frontend\" \"npm run dev --prefix backend\"",
    "build": "npm run build --prefix frontend",
    "build:all": "npm run build --prefix frontend",
    "start": "npm run start --prefix backend",
    "lint": "npm run lint --prefix frontend",
    "preview": "npm run preview --prefix frontend",
    "seed": "npm run seed --prefix backend",
    "install:all": "npm install --prefix frontend && npm install --prefix backend",
    "kill-port": "npx kill-port 5001",
    "fresh": "npx kill-port 5001 && npm run dev:all"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
